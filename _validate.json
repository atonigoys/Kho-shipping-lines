    {
      "id": "calc-date-range",
      "name": "Calculate Date Range",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1380, 0],
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Workflow runs Monday. Compute previous Sun -> Sat window.\nconst trigger = $input.first()?.json ?? {};\nconst now = new Date();\nconst dow = now.getUTCDay(); // 0=Sun ... 6=Sat\n// On Monday (dow=1), previous Sunday is 8 days back; previous Saturday 2 days back.\nconst daysSincePrevSunday = dow === 0 ? 7 : dow + 7;\nconst start = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate() - daysSincePrevSunday));\nconst end = new Date(Date.UTC(start.getUTCFullYear(), start.getUTCMonth(), start.getUTCDate() + 6));\n\nconst fmt = d => d.toISOString().slice(0, 10);\nconst sevenDaysAgo = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate() - 7));\n\n// ISO week key: YYYY-Www\nfunction isoWeek(d) {\n  const t = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n  const day = t.getUTCDay() || 7;\n  t.setUTCDate(t.getUTCDate() + 4 - day);\n  const yearStart = new Date(Date.UTC(t.getUTCFullYear(), 0, 1));\n  const weekNo = Math.ceil((((t - yearStart) / 86400000) + 1) / 7);\n  return `${t.getUTCFullYear()}-W${String(weekNo).padStart(2, '0')}`;\n}\n\nreturn [{\n  json: {\n    triggeredAt: trigger.timestamp ?? now.toISOString(),\n    startDate: fmt(start),\n    endDate: fmt(end),\n    sevenDaysAgo: fmt(sevenDaysAgo),\n    runDate: fmt(now),\n    weekKey: isoWeek(start),\n    advertiserId: 81733,\n    program: 'GREEN ROADS'\n  }\n}];"
      }
    },
