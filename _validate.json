    {
      "id": "merge-contact",
      "name": "Merge Contact",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 200],
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Find a fallback row matching this publisher_id (Sheets read returns ALL rows here).\nconst pub = $('Per-Publisher Loop').item.json;\nconst rows = $input.all().map(i => i.json);\nconst match = rows.find(r => String(r.publisher_id) === String(pub.publisher_id)) || {};\nconst email = match.email || pub.email || '';\nreturn [{ json: { ...pub, email, _contact_source: email && !pub.email ? 'fallback' : 'awin' } }];"
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "build-email",
      "name": "Build Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 0],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const items = $input.all();\nreturn items.map(it => {\n  const p = it.json;\n  const name = p.publisher_name || 'Partner';\n  const LOW_PERF_SUBJECT = \"Let's Improve Your GREEN ROADS Campaign Performance\";\n  const NEW_PUB_SUBJECT  = \"Welcome to GREEN ROADS Affiliate Program\";\n\n  const LOW_PERF_BODY = `Hi ${name},\\n\\nWe noticed your publisher account generated low activity last week.\\n\\nWe'd love to help optimize your placements and improve performance for GREEN ROADS campaigns.\\n\\nLet us know if you need:\\n- updated creatives\\n- landing pages\\n- coupon offers\\n- exclusive promotions\\n\\nLooking forward to working together.\\n\\nBest,\\nGREEN ROADS Affiliate Team`;\n\n  const NEW_PUB_BODY = `Hi ${name},\\n\\nWelcome to the GREEN ROADS affiliate program.\\n\\nWe're excited to work with you.\\n\\nHere are some things we can provide:\\n- top converting creatives\\n- coupon codes\\n- landing pages\\n- custom support\\n\\nReply anytime if you need help getting started.\\n\\nBest,\\nGREEN ROADS Affiliate Team`;\n\n  let subject, body;\n  if (p.category === 'new_publisher') { subject = NEW_PUB_SUBJECT; body = NEW_PUB_BODY; }\n  else { subject = LOW_PERF_SUBJECT; body = LOW_PERF_BODY; }\n\n  return { json: { ...p, email_subject: subject, email_body: body } };\n});"
      }
    },
