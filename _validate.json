    {
      "id": "normalize",
      "name": "Normalize & Filter GREEN ROADS",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-660, 0],
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Inputs from merge: item 0 = performance report, item 1 = publishers list.\n// AWIN endpoints can return arrays directly or wrapped â€” handle both.\nfunction asArray(x) {\n  if (!x) return [];\n  if (Array.isArray(x)) return x;\n  if (Array.isArray(x.data)) return x.data;\n  if (Array.isArray(x.items)) return x.items;\n  if (Array.isArray(x.publishers)) return x.publishers;\n  return [];\n}\n\nconst dateCtx = $('Calculate Date Range').item.json;\nconst all = $input.all();\nconst perfRaw = all[0]?.json ?? {};\nconst pubsRaw = all[1]?.json ?? {};\n\nconst performance = asArray(perfRaw);\nconst publishers  = asArray(pubsRaw);\n\n// Build a lookup of publisher metadata (join date, email, name)\nconst pubMap = new Map();\nfor (const p of publishers) {\n  const id = p.id ?? p.publisherId ?? p.publisher?.id;\n  if (id == null) continue;\n  pubMap.set(String(id), {\n    publisher_name: p.name ?? p.publisherName ?? p.publisher?.name ?? '',\n    email: p.email ?? p.contactEmail ?? p.publisher?.email ?? '',\n    join_date: p.joinedDate ?? p.dateJoined ?? p.joinDate ?? p.relationshipDate ?? null\n  });\n}\n\n// Normalize performance rows. Filter to GREEN ROADS commission groups only.\nconst out = [];\nconst seen = new Set();\nfor (const row of performance) {\n  const groupName = (row.commissionGroupName || row.commissionGroup || '').toString();\n  if (groupName && !/green\\s*roads/i.test(groupName)) continue;\n\n  const id = String(row.publisherId ?? row.publisher?.id ?? row.id ?? '');\n  if (!id || seen.has(id)) continue;\n  seen.add(id);\n  const meta = pubMap.get(id) || {};\n\n  out.push({\n    json: {\n      publisher_id: id,\n      publisher_name: row.publisherName ?? row.publisher?.name ?? meta.publisher_name ?? '',\n      email: meta.email ?? row.publisherEmail ?? '',\n      clicks: Number(row.clicks ?? 0),\n      transactions: Number(row.transactionsCount ?? row.transactions ?? 0),\n      revenue: Number(row.totalSaleAmount?.amount ?? row.saleAmount?.amount ?? row.revenue ?? 0),\n      commission: Number(row.totalCommissionAmount?.amount ?? row.commissionAmount?.amount ?? row.commission ?? 0),\n      join_date: meta.join_date,\n      commission_group: groupName,\n      _ctx: dateCtx\n    }\n  });\n}\n\n// Add publishers that joined in the last 7 days but had no perf rows yet\nfor (const [id, meta] of pubMap.entries()) {\n  if (seen.has(id)) continue;\n  if (!meta.join_date) continue;\n  const joined = new Date(meta.join_date);\n  if (Number.isNaN(joined.getTime())) continue;\n  const sevenDaysAgo = new Date(dateCtx.sevenDaysAgo);\n  if (joined < sevenDaysAgo) continue;\n  out.push({\n    json: {\n      publisher_id: id,\n      publisher_name: meta.publisher_name,\n      email: meta.email,\n      clicks: 0,\n      transactions: 0,\n      revenue: 0,\n      commission: 0,\n      join_date: meta.join_date,\n      commission_group: 'GREEN ROADS',\n      _ctx: dateCtx\n    }\n  });\n}\n\nreturn out;"
      }
    },
