    {
      "id": "categorize",
      "name": "Categorize + Dedupe",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-220, 0],
      "parameters": {
        "language": "javaScript",
        "jsCode": "// $input has rows from 'Already Emailed This Week'. Pull publishers from the upstream Normalize step.\nconst alreadyRaw = $input.all().map(i => i.json);\nconst alreadySet = new Set(\n  alreadyRaw\n    .map(r => `${r.publisher_id}|${r.email_type || r.category || ''}`)\n    .filter(Boolean)\n);\n\nconst pubs = $('Normalize & Filter GREEN ROADS').all().map(i => i.json);\nconst dateCtx = $('Calculate Date Range').item.json;\nconst sevenDaysAgo = new Date(dateCtx.sevenDaysAgo);\n\nconst out = [];\nfor (const p of pubs) {\n  const categories = [];\n  const joined = p.join_date ? new Date(p.join_date) : null;\n  const isNew = joined && !Number.isNaN(joined.getTime()) && joined >= sevenDaysAgo;\n  const lowClicks = p.clicks < 100 && p.transactions === 0;\n  const lowPerf = p.transactions === 0 || p.revenue < 20;\n\n  if (isNew) categories.push('new_publisher');\n  else if (lowClicks) categories.push('low_clicks');\n  else if (lowPerf) categories.push('low_performance');\n\n  for (const cat of categories) {\n    const dedupeKey = `${p.publisher_id}|${cat}`;\n    if (alreadySet.has(dedupeKey)) continue;\n    out.push({\n      json: {\n        publisher_id: p.publisher_id,\n        publisher_name: p.publisher_name,\n        email: p.email,\n        clicks: p.clicks,\n        transactions: p.transactions,\n        revenue: p.revenue,\n        commission: p.commission,\n        join_date: p.join_date,\n        commission_group: p.commission_group,\n        category: cat,\n        week_key: dateCtx.weekKey,\n        run_date: dateCtx.runDate\n      }\n    });\n  }\n}\nreturn out;"
      }
    },
