    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const raw = $json.scraped_website || $json.primaryUrl || $json.displayUrl || '';\n\nconst domain = raw\n  .replace(/https?:\\/\\//i, '')\n  .replace(/^www\\./i, '')\n  .split('/')[0]\n  .split('?')[0]\n  .trim()\n  .toLowerCase();\n\nconst isValid = domain.length > 3 && domain.includes('.');\n\nreturn [{ json: { ...$json, domain: isValid ? domain : null, domain_valid: isValid } }];"
      },
