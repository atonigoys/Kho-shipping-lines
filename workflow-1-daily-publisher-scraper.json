    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst used = staticData.hunterCallsThisMonth || 0;\nconst LIMIT = $vars.HUNTER_MONTHLY_LIMIT || 480;\n\nif (used >= LIMIT) {\n  throw new Error(\n    `Hunter.io monthly budget reached: ${used}/${LIMIT} calls used. ` +\n    `Reset counter in Static Data or upgrade your Hunter.io plan.`\n  );\n}\n\nreturn [{ json: { ...$json, hunter_calls_used: used, hunter_remaining: LIMIT - used } }];"
      },
