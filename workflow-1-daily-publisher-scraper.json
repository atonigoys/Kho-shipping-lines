    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const now = new Date();\nconst startDate = new Date(now.getFullYear(), now.getMonth(), 1)\n  .toISOString().split('T')[0];\nconst endDate = now.toISOString().split('T')[0];\nreturn [{ json: { startDate, endDate } }];"
