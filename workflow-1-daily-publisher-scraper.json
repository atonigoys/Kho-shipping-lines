    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const data = $json.data || {};\nconst emails = data.emails || [];\n\nconst best = emails\n  .filter(e => (e.confidence || 0) >= 70)\n  .sort((a, b) => (b.confidence || 0) - (a.confidence || 0))[0] || emails[0] || {};\n\nreturn [{\n  json: {\n    ...$json,\n    hunter_email:       best.value || null,\n    hunter_first_name:  best.first_name || null,\n    hunter_last_name:   best.last_name || null,\n    hunter_confidence:  best.confidence || null,\n    hunter_email_type:  best.type || null,\n    hunter_org:         data.organization || null,\n    hunter_phone:       data.phone_number || null\n  }\n}];"
      },
      "id": "n7c",
      "name": "Extract Best Hunter.io Email Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4100, 360]
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nstaticData.hunterCallsThisMonth = (staticData.hunterCallsThisMonth || 0) + 1;\nreturn [{ json: { ...$json, hunter_total_calls: staticData.hunterCallsThisMonth } }];"
      },
