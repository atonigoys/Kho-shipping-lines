    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const d = $json;\n\nconst email = d.scraped_email || d.hunter_email || '';\nconst emailSource = d.scraped_email ? 'AWIN Profile'\n                  : d.hunter_email  ? 'Hunter.io'\n                  : 'Not Found';\n\nconst contactName = d.scraped_contact_name\n  || [d.hunter_first_name, d.hunter_last_name].filter(Boolean).join(' ')\n  || '';\n\nconst phone = d.scraped_phone || d.hunter_phone || '';\n\nreturn [{\n  json: {\n    publisher_id:      d.id,\n    publisher_name:    d.name || d.publisherName || '',\n    contact_name:      contactName,\n    email:             email,\n    email_source:      emailSource,\n    email_confidence:  d.hunter_confidence || '',\n    phone:             phone,\n    website:           d.scraped_website || d.domain || '',\n    domain:            d.domain || '',\n    promo_type:        d.primaryType || '',\n    region:            d.primaryRegion || '',\n    clicks:            d.clicks || 0,\n    impressions:       d.impressions || 0,\n    transactions:      d.totalNo || 0,\n    commission:        d.totalComm || 0,\n    status:            'active',\n    date_scraped:      new Date().toISOString().split('T')[0]\n  }\n}];"
      },
      "id": "n8a",
      "name": "Build Final Enriched Publisher Record",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4560, 240]
    },
