        "jsCode": "const incoming = $('Build Final Enriched Publisher Record').item.json;\nconst existing = $('Read Existing Publisher IDs from Sheet').all()\n  .map(r => String(r.json.publisher_id));\n\nconst alreadySaved = existing.includes(String(incoming.publisher_id));\n\nreturn [{ json: { ...incoming, already_saved: alreadySaved } }];"
      },
