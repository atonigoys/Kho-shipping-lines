        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst attempt = staticData.retryAttempt || 1;\nconst baseDelay = 3000;\nconst maxDelay = 60000;\nconst jitter = Math.random() * 1000;\nconst delay = Math.min(baseDelay * Math.pow(2, attempt - 1) + jitter, maxDelay);\nstaticData.retryAttempt = attempt + 1;\nreturn [{ json: { ...$json, delay_ms: Math.round(delay), attempt } }];"
      },
