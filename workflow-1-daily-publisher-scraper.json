    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "const html = $json.data || $json.body || '';\n\n// Email from mailto: links\nconst emailMatch = html.match(/href=[\"']mailto:([^\"']+)[\"']/i);\nconst email = emailMatch ? emailMatch[1].trim().toLowerCase() : null;\n\n// Phone\nconst phoneMatch = html.match(/(?:tel:|phone|mobile|contact)[\\s\\S]{0,50}?([\\+\\d][\\d\\s\\-\\(\\)]{6,20})/i);\nconst phone = phoneMatch ? phoneMatch[1].replace(/\\s+/g, '').trim() : null;\n\n// Contact name (Firstname Lastname pattern)\nconst nameMatch = html.match(/(?:contact(?:\\s+name)?|account\\s+manager|fn)[\\s\\S]{0,100}?<[^>]+>\\s*([A-Z][a-z]+ [A-Z][a-z]+)/i);\nconst contactName = nameMatch ? nameMatch[1].trim() : null;\n\n// Website URL\nconst websiteMatch = html.match(/(?:website|primary\\s*url|promotional\\s*url)[\\s\\S]{0,200}?href=[\"'](https?:\\/\\/[^\"']+)[\"']/i);\nconst website = websiteMatch ? websiteMatch[1].trim() : null;\n\nconst contactHidden = /contact.*hidden|privacy.*setting|not\\s+publicly/i.test(html);\n\nreturn [{\n  json: {\n    ...$json,\n    scraped_email:        email,\n    scraped_phone:        phone,\n    scraped_contact_name: contactName,\n    scraped_website:      website,\n    contact_hidden:       contactHidden,\n    profile_scraped:      true\n  }\n}];"
      },
      "id": "n5b",
      "name": "Parse Publisher Profile HTML",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2560, 240]
